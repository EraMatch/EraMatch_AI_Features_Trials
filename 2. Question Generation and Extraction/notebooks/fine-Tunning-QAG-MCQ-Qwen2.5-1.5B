5"}},"outputId":"c376b9e8-cca4-4072-fea3-4d17f267e84d"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["[transformers] The tokenizer has new PAD/BOS/EOS tokens that differ from the model config and generation config. The model config and generation config were aligned accordingly, being updated with the tokenizer's values. Updated tokens: {'bos_token_id': None, 'pad_token_id': 151643}.\n"]},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["\n","    <div>\n","      \n","      <progress value='189' max='189' style='width:300px; height:20px; vertical-align: middle;'></progress>\n","      [189/189 34:43, Epoch 3/3]\n","    </div>\n","    <table border=\"1\" class=\"dataframe\">\n","  <thead>\n"," <tr style=\"text-align: left;\">\n","      <th>Step</th>\n","      <th>Training Loss</th>\n","      <th>Validation Loss</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <td>50</td>\n","      <td>1.507406</td>\n","      <td>1.498424</td>\n","    </tr>\n","    <tr>\n","      <td>100</td>\n","      <td>1.432796</td>\n","      <td>1.464294</td>\n","    </tr>\n","    <tr>\n","      <td>150</td>\n","      <td>1.372759</td>\n","      <td>1.449546</td>\n","    </tr>\n","    <tr>\n","      <td>189</td>\n","      <td>1.357563</td>\n","      <td>1.445561</td>\n","    </tr>\n","  </tbody>\n","</table><p>"]},"metadata":{}},{"output_type":"execute_result","data":{"text/plain":["TrainOutput(global_step=189, training_loss=1.4683140547817977, metrics={'train_runtime': 2094.8668, 'train_samples_per_second': 2.846, 'train_steps_per_second': 0.09, 'total_flos': 2.2535577121867776e+16, 'train_loss': 1.4683140547817977, 'epoch': 3.0})"]},"metadata":{},"execution_count":21}]},{"source":["!zip -r \"/content/QWEN-2.5-1.5B-MCQ.zip\" \"/content/outputs\""],"metadata":{"id":"gUgXvmPGZkuW","colab":{"base_uri":"https://localhost:8080/","height":781,"referenced_widgets":["ca69f46a6e4245b99582a01a0bff1f04","07a7144745a54bbe8237f73bafada5df","931bd37ba4a54780b64e93acef787930","455b68e1372b4130871a4bb6dc63e993","1c52ce40982f40d89695ef51ee243817","1332791edff14ea081945f7cb13610c9","825f477286b54da0989d5ccee07a80e1","76c3fcc24cf04dbf8973cf0e213db5ff","56af54ab5efd4ffe93a6d57abd40e37d","3924c322f1db44aa98b641cef273f4fa","1805a0fa426f4a388fa8af4b33a30151"]},"executionInfo":{"status":"ok","timestamp":1780313232178,"user_tz":-180,"elapsed":86996,"user":{"displayName":"Adham Ashraf 202200953","userId":"08988520979598682415"}},"outputId":"64ca73b0-63b2-434b-a3b0-ddf4a151dea6"},"cell_type":"code","outputs":[{"output_type":"stream","name":"stdout","text":["updating: content/outputs/ (stored 0%)\n","updating: content/outputs/STABLE_QWEN_MCQ/ (stored 0%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/ (stored 0%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/README.md (deflated 65%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/optimizer.pt (deflated 8%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/scheduler.pt (deflated 62%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/tokenizer.json (deflated 81%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/chat_template.jinja (deflated 71%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/training_args.bin (deflated 54%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/adapter_model.safetensors (deflated 8%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/trainer_state.json (deflated 75%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/tokenizer_config.json (deflated 60%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/rng_state.pth (deflated 26%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/scaler.pt (deflated 64%)\n","updating: content/outputs/STABLE_QWEN_MCQ/checkpoint-189/adapter_config.json (deflated 60%)\n","Loading Trained MCQ Model...\n"]},{"output_type":"display_data","data":{"text/plain":["Loading weights:   0%|          | 0/338 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"ca69f46a6e4245b99582a01a0bff1f04"}},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Scenario: You are designing a high-performance data processing pipeline that requires sorting large datasets in a distributed environment. The system must be able to handle thousands of concurrent requests without hitting performance bottlenecks from recursive function calls.\n","Question: Why is it unacceptable to implement Quicksort iteratively in this system?\n","Choices:\n","A) A) Iterative implementation would be too slow due to the overhead of manual stack management.\n","B) B) The recursive nature of Quicksort ensures that the algorithm can handle large input sizes without compromising performance.\n","C) C) Implementing Quicksort iteratively would require managing a manual stack structure, which is not thread-safe and could lead to race conditions.\n","D) D) Iterative implementation would not be able to take advantage of multi-core CPUs and would lead to suboptimal parallelization.\n","Answer: C) Implementing Quicksort iteratively would require managing a manual stack structure, which is not thread-safe and could lead to race conditions.\n","Question: Why is it not feasible to use a recursive Quicksort implementation in this distributed data processing pipeline?\n","Choices:\n","A) A) Recursive Quicksort requires too much memory to store intermediate results.\n","B) B) Recursive Quicksort would cause a stack overflow due to the large number of recursive calls.\n","C) C) Recursive Quicksort cannot handle large input sizes without compromising performance.\n","D) D) Recursive Quicksort would require managing a manual stack structure, which is not thread-safe and could lead to race conditions.\n","Answer: D) Recursive Quicksort would require managing a manual stack structure, which is not thread-safe and could lead to race conditions.\n","======================================================================\n","\n","Scenario: You are building a real-time analytics platform that needs to process and analyze massive log files from various sources. The system must be able to handle thousands of concurrent requests without hitting performance bottlenecks from recursive function calls.\n","Question: Why would implementing Quicksort iteratively in this system lead to suboptimal performance?\n","Choices:\n","A) A) Iterative implementation would be too slow due to the overhead of manual stack management.\n","B) B) The recursive nature of Quicksort ensures that the algorithm can handle large input sizes without compromising performance.\n","C) C) Implementing Quicksort iteratively would require managing a manual stack structure, which is not thread-safe and could lead to race conditions.\n","D) D) Iterative implementation would not be able to take advantage of multi-core CPUs and would lead to suboptimal parallelization.\n","Answer: C) Implementing Quicksort\n"]}],"execution_count":null},{"cell_type":"code","source":["from peft import PeftModel\n","from transformers import AutoModelForCausalLM, AutoTokenizer, StoppingCriteria, StoppingCriteriaList\n","import torch\n","\n","BASE_MODEL = \"Qwen/Qwen2.5-1.5B\"\n","QWEN_LORA_DIR = \"./outputs/STABLE_QWEN_MCQ/checkpoint-189\"\n","\n","print(\"Loading Trained MCQ Model...\")\n","tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL)\n","base_model = AutoModelForCausalLM.from_pretrained(\n","    BASE_MODEL, device_map=\"auto\", torch_dtype=torch.float16\n",")\n","model = PeftModel.from_pretrained(base_model, QWEN_LORA_DIR)\n","\n","class StopOnEosCriteria(StoppingCriteria):\n","    def __init__(self, eos_token_id):\n","        self.eos_token_id = eos_token_id\n","\n","    def __call__(self, input_ids: torch.LongTensor, scores: torch.FloatTensor, **kwargs) -> bool:\n","        return input_ids[0, -1].item() == self.eos_token_id\n","\n","def ask_qwen_mcq(context_text):\n","    prompt = f\"Context: {context_text}\\n\\nScenario:\"\n","    inputs = tokenizer(prompt, return_tensors=\"pt\").to(model.device)\n","\n","    stopping_criteria = StoppingCriteriaList([StopOnEosCriteria(tokenizer.eos_token_id)])\n","\n","    outputs = model.generate(\n","        **inputs,\n","        max_new_tokens=512,\n","        temperature=0.7,\n","        do_sample=True,\n","        pad_token_id=tokenizer.eos_token_id,\n","        eos_token_id=tokenizer.eos_token_id,\n","        stopping_criteria=stopping_criteria\n","    )\n","\n","    full_text = tokenizer.decode(outputs[0], skip_special_tokens=True)\n","    generated_output = full_text[len(prompt):].strip()\n","    return f\"Scenario: {generated_output}\"\n","\n","sample_context = \"\"\"\n","Pillar: DSA/Applied_Enginering # Source_Book: Java3e20110103\n","Quicksort is inherently recursive, because each Quicksort operation must sort two sublists.\n","Implementing it iteratively requires managing a manual stack structure.\n","\"\"\"\n","print(ask_qwen_mcq(sample_context))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":277,"referenced_widgets":["035ae3ba504647e881372f60c775e535","c45131b878b742f085c494ebd7d3a71a","c3d338bfe8304c19bd199e9fe7052a69","0ebd25ceac144d5daff7389e9e76ac30","893e2909da664b83950a3f46e7bddbf4","c527180698074f849046ca3ac5e712b9","17421934ae0a407ebbfc6c9bef79d753","c7a0c65c920c4184a4bfc1f00f542252","e41cc7cd10554c0f813f13ed764da770","3e6cb530f8d44f0ea0015e93028abbe4","97f7dcc0670d4977b73ba68fe2812f5d"]},"id":"TAaf1yRE7r6d","executionInfo":{"status":"ok","timestamp":1780313538193,"user_tz":-180,"elapsed":74599,"user":{"displayName":"Adham Ashraf 202200953","userId":"08988520979598682415"}},"outputId":"ff37df9f-f986-4bab-b6b8-958a184f0bff"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["WARNING:torchao:Failed to load /usr/local/lib/python3.12/dist-packages/torchao/_C_mxfp8.cpython-310-x86_64-linux-gnu.so: Could not load this library: /usr/local/lib/python3.12/dist-packages/torchao/_C_mxfp8.cpython-310-x86_64-linux-gnu.so\n","WARNING:torchao:Failed to load /usr/local/lib/python3.12/dist-packages/torchao/_C_cutlass_90a.abi3.so: Could not load this library: /usr/local/lib/python3.12/dist-packages/torchao/_C_cutlass_90a.abi3.so\n"]},{"output_type":"stream","name":"stdout","text":["Loading Trained MCQ Model...\n"]},{"output_type":"stream","name":"stderr","text":["[transformers] `torch_dtype` is deprecated! Use `dtype` instead!\n"]},{"output_type":"display_data","data":{"text/plain":["Loading weights:   0%|          | 0/338 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"035ae3ba504647e881372f60c775e535"}},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Scenario: You are tasked with optimizing the Quicksort implementation for a high-performance data processing pipeline. The system requires minimizing memory usage and CPU cycles while ensuring correctness.\n","Question: Why would implementing Quicksort as an iterative algorithm be a poor choice in this specific scenario?\n","Choices:\n","A) A) Iterative implementations are inherently slower and use more memory than recursive ones.\n","B) B) Manual stack management is impractical for large input sizes and requires significant extra code.\n","C) C) The iterative approach does not handle edge cases like duplicate keys and outliers well.\n","D) D) It violates the recursive constraints of the Quicksort algorithm by not using the divide and conquer paradigm.\n","Answer: B) Manual stack management is impractical for large input sizes and requires significant extra code.\n"]}]},{"cell_type":"code","source":["from google.colab import files\n","files.download(\"/content/QWEN-2.5-1.5B-MCQ.zip\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":17},"id":"fLdAtcW28mP9","executionInfo":{"status":"ok","timestamp":1780313790045,"user_tz":-180,"elapsed":27,"user":{"displayName":"Adham Ashraf 202200953","userId":"08988520979598682415"}},"outputId":"4d7d42b6-b37a-4c6b-f691-ff58f6ff4c2f"},"execution_count":4,"outputs":[{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["\n","    async function download(id, filename, size) {\n","      if (!google.colab.kernel.accessAllowed) {\n","        return;\n","      }\n","      const div = document.createElement('div');\n","      const label = document.createElement('label');\n","      label.textContent = `Downloading \"${filename}\": `;\n","      div.appendChild(label);\n","      const progress = document.createElement('progress');\n","      progress.max = size;\n","      div.appendChild(progress);\n","      document.body.appendChild(div);\n","\n","      const buffers = [];\n","      let downloaded = 0;\n","\n","      const channel = await google.colab.kernel.comms.open(id);\n","      // Send a message to notify the kernel that we're ready.\n","      channel.send({})\n","\n","      for await (const message of channel.messages) {\n","        // Send a message to notify the kernel that we're ready.\n","        channel.send({})\n","        if (message.buffers) {\n","          for (const buffer of message.buffers) {\n","            buffers.push(buffer);\n","            downloaded += buffer.byteLength;\n","            progress.value = downloaded;\n","          }\n","        }\n","      }\n","      const blob = new Blob(buffers, {type: 'application/binary'});\n","      const a = document.createElement('a');\n","      a.href = window.URL.createObjectURL(blob);\n","      a.download = filename;\n","      div.appendChild(a);\n","      a.click();\n","      div.remove();\n","    }\n","  "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["download(\"download_e7745a8f-d7d9-4b48-a03d-461c6116e1a1\", \"QWEN-2.5-1.5B-MCQ.zip\", 206066505)"]},"metadata":{}}]},{"cell_type":"code","source":[],"metadata":{"id":"hdoAtL9B9wnI"},"execution_count":null,"outputs":[]}]}