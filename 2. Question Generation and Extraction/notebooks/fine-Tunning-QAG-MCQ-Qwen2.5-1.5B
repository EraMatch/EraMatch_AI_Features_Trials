el_module":"@jupyter-widgets/controls","model_name":"DescriptionStyleModel","model_module_version":"1.5.0","state":{"_model_module":"@jupyter-widgets/controls","_model_module_version":"1.5.0","_model_name":"DescriptionStyleModel","_view_count":null,"_view_module":"@jupyter-widgets/base","_view_module_version":"1.2.0","_view_name":"StyleView","description_width":""}}}}},"nbformat_minor":0,"nbformat":4,"cells":[{"cell_type":"markdown","source":["`https://drive.google.com/file/d/1F2g99FpI8LULl3AtrfZEoA03Ll0cFUc5/view?usp=sharing`"],"metadata":{"id":"lFe3NGjMnrwV"}},{"cell_type":"code","source":["# IMPORTANT: RUN THIS CELL IN ORDER TO IMPORT YOUR KAGGLE DATA SOURCES,\n","# THEN FREE TO DELETE THIS CELL.\n","import kagglehub\n","adhamashraf202200953_technical_parsed_questions_path = kagglehub.dataset_download('adhamashraf202200953/technical-parsed-questions')\n","\n","print('Data source import complete.')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LlveJrwKw15F","executionInfo":{"status":"ok","timestamp":1780310880056,"user_tz":-180,"elapsed":1199,"user":{"displayName":"Adham Ashraf 202200953","userId":"08988520979598682415"}},"outputId":"1ddd1b39-66fb-4686-8656-d0a0eb5d1a20"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Using Colab cache for faster access to the 'technical-parsed-questions' dataset.\n","Data source import complete.\n"]}]},{"cell_type":"code","source":["# # Upgrade PyTorch to a unified CUDA 12.1 version\n","# !pip install --upgrade torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121\n","\n","# # Install and upgrade all Hugging Face and evaluation libraries together\n","# !pip install --upgrade transformers datasets evaluate accelerate peft bitsandbytes sentencepiece rouge_score bert_score nltk"],"metadata":{"id":"as8Qwiqww4QA"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# !pip install --upgrade torchao"],"metadata":{"id":"YXCh5q9py31Q"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import gc\n","import torch\n","import os\n","import glob\n","import pandas as pd\n","from datasets import Dataset\n","from transformers import (\n","    TrainingArguments,\n","    Trainer,\n","    AutoTokenizer,\n","    AutoModelForCausalLM,\n","    DataCollatorForLanguageModeling\n",")\n","from peft import LoraConfig, get_peft_model, TaskType"],"metadata":{"id":"mGRIZQSFw5RP"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def preprocess_function(examples):\n","    full_texts = []\n","\n","    for i in range(len(examples[\"context\"])):\n","        c = examples[\"context\"][i]\n","        s = examples[\"scenario_context\"][i]\n","        q = examples[\"question\"][i]\n","\n","        c0 = examples[\"choices/0\"][i]\n","        c1 = examples[\"choices/1\"][i]\n","        c2 = examples[\"choices/2\"][i]\n","        c3 = examples[\"choices/3\"][i]\n","\n","        ans = examples[\"correct_choice\"][i]\n","\n","        text = (\n","            f\"Context: {str(c).strip()}\\n\\n\"\n","            f\"Scenario: {str(s).strip()}\\n\"\n","            f\"Question: {str(q).strip()}\\n\"\n","            f\"Choices:\\n\"\n","            f\"A) {str(c0).strip()}\\n\"\n","            f\"B) {str(c1).strip()}\\n\"\n","            f\"C) {str(c2).strip()}\\n\"\n","            f\"D) {str(c3).strip()}\\n\"\n","            f\"Answer: {str(ans).strip()}{tokenizer.eos_token}\"\n","        )\n","        full_texts.append(text)\n","\n","    model_inputs = tokenizer(full_texts, max_length=MAX_LENGTH, truncation=True)\n","    return model_inputs"],"metadata":{"id":"UP6fj559ycfK"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["MODEL_NAME = \"Qwen/Qwen2.5-1.5B\"\n","DATA_FOLDER = \"/root/.cache/kagglehub/datasets/adhamashraf202200953/technical-parsed-questions/versions/5\"\n","OUTPUT_DIR = \"./outputs/STABLE_QWEN_MCQ\"\n","\n","BATCH_SIZE = 2\n","GRADIENT_ACC_STEPS = 16\n","MAX_LENGTH = 512\n","\n","gc.collect()\n","torch.cuda.empty_cache()\n","\n","csv_files = glob.glob(os.path.join(DATA_FOLDER, \"*_mcq.csv\"))\n","if not csv_files:\n","    raise FileNotFoundError(f\"No MCQ CSV files found in {DATA_FOLDER}\")\n","\n","required_columns = [\n","    \"context\", \"scenario_context\", \"question\",\n","    \"choices/0\", \"choices/1\", \"choices/2\", \"choices/3\",\n","    \"correct_choice\"\n","]\n","\n","all_dfs = []\n","for file_path in csv_files:\n","    try:\n","        df = pd.read_csv(file_path, nrows=2)\n","\n","        if not all(col in df.columns for col in required_columns):\n","            print(f\"Skipping corrupt or mismatched file: {os.path.basename(file_path)}\")\n","            continue\n","\n","        df_clean = pd.read_csv(file_path, usecols=required_columns)\n","        all_dfs.append(df_clean)\n","        print(f\"Successfully loaded {os.path.basename(file_path)} ({len(df_clean)} rows)\")\n","    except Exception as e:\n","        print(f\"Error reading {os.path.basename(file_path)}: {e}\")\n","\n","if not all_dfs:\n","    raise ValueError(\"No valid MCQ files could be loaded with the required columns.\")\n","\n","combined_df = pd.concat(all_dfs, ignore_index=True)\n","combined_df = combined_df.dropna(subset=[\"context\", \"question\", \"correct_choice\"])\n","\n","dataset = Dataset.from_pandas(combined_df)\n","print(f\"\\nFinal unified dataset size: {len(dataset)} samples.\")\n","\n","tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n","if tokenizer.pad_token is None:\n","    tokenizer.pad_token = tokenizer.eos_token\n","\n","tokenized_dataset = dataset.map(preprocess_function, batched=True, remove_columns=dataset.column_names)\n","split_dataset = tokenized_dataset.train_test_split(test_size=0.1)\n","\n","model = AutoModelForCausalLM.from_pretrained(\n","    MODEL_NAME,\n","    device_map=\"auto\",\n","    torch_dtype=torch.float16\n",")\n","\n","peft_config = LoraConfig(\n","    r=16,\n","    lora_alpha=32,\n","    target_modules=[\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"],\n","    lora_dropout=0.1,\n","    task_type=TaskType.CAUSAL_LM\n",")\n","model = get_peft_model(model, peft_config)\n","\n","print(\"Total training samples:\", len(split_dataset[\"train\"]))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":257,"referenced_widgets":["bd74cb5f23e54d00be0a932e3ca2c0e4","79ab5dd2a94449288d6a08237fbd4508","c5f9e32f04844f049766d809b2654fa6","5b64fa8c9a634bc0b83f5b32cb3d34e9","a4644af1025c4ee6abc21c2903c13f8a","ecfd4cee5f594af7a3d42f7a7cb35744","9f45b4aeb7304fb3a2ead5e6762f56ea","4fc97761f66149fc9c66aa94612d00e7","a1496c95390e4ae7ba326100509a7cc0","0cf86cda08b448d1abb7d5521d1c8d32","20fcb84a0bfd402fa1b7f6f9ca6804fb","7e8e37c0d1504233bb2769a1aa3c3d78","da8deff136ed47d183e9d4d7605e3737","59e5b72a523b4009ac7830153faa8b8e","ea07b55213da477ca758cf322b3fe5e6","32b25594f21e460aae0295f51e1ec0e1","86441a0f67a74c259f08439b435eed01","fcc07db4db0947f2ade1f473fe72f48d","68725627824740ae8d92b5fda4fe670c","2e7948fb5b6545db95d110354d0e8b59","ef78f2fddfdb45bc8d4f73fabc237499","3b73687859bb4f6ea5394e9fee8d5eca"]},"id":"mAnd8a-Pw_bC","executionInfo":{"status":"ok","timestamp":1780310898740,"user_tz":-180,"elapsed":17984,"user":{"displayName":"Adham Ashraf 202200953","userId":"08988520979598682415"}},"outputId":"422f0539-87a1-4c53-8dd8-4d64e7a4f859"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Successfully loaded SWE_Abstract_Theory_mcq.csv (761 rows)\n","Skipping corrupt or mismatched file: DSA_Abstract_Theory_mcq.csv\n","Successfully loaded DSA_Applied_Enginering_mcq.csv (732 rows)\n","Successfully loaded ML_DS_Abstract_Theory_mcq.csv (715 rows)\n","\n","Final unified dataset size: 2208 samples.\n"]},{"output_type":"display_data","data":{"text/plain":["Map:   0%|          | 0/2208 [00:00<?, ? examples/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"bd74cb5f