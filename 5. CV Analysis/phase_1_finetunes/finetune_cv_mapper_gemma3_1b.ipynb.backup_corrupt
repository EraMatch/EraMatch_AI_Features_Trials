    "    fuzzy_li_prec, fuzzy_li_rec = li_score, li_score\n",
    "\n",
    "    fuzzy_skills_pr = fuzzy_set_pr(pred_skills, true_skills)\n",
    "    fuzzy_companies_pr = fuzzy_set_pr(pred_companies, true_companies)\n",
    "    fuzzy_titles_pr = fuzzy_set_pr(pred_titles, true_titles)\n",
