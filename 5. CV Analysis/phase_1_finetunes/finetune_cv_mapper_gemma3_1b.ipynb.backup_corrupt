    "    ]:\n",
    "        total_gt_items += len(true_set)\n",
    "        missing_count += len(true_set - pred_set)\n",
    "\n",
    "    missing_field_rate = (\n",
    "        round(missing_count / total_gt_items, 3) if total_gt_items > 0 else 0.0\n",
    "    )\n",
    "\n",
    "    fuzzy_fn_prec, fuzzy_fn_rec = (\n",
