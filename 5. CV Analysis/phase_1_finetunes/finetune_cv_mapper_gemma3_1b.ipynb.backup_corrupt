    "    )\n",
    "    f_skills_pr = fuzzy_set_pr(pred_skills, true_skills)\n",
    "    f_companies_pr = fuzzy_set_pr(pred_companies, true_companies)\n",
    "    f_titles_pr = fuzzy_set_pr(pred_titles, true_titles)\n",
    "    f_insts_pr = fuzzy_set_pr(pred_insts, true_insts)\n",
    "    f_degrees_pr = fuzzy_set_pr(pred_degrees, true_degrees)\n",
    "    fuzzy_match_f1 = (\n",
    "        round(\n",
    "            (\n",
    "                f_fn[0]\n",
    "                + f_em[0]\n",
    "                + f_loc[0]\n",
    "                + f_sen[0]\n",
    "                + f_dom[0]\n",
    "                + f_skills_pr[0]\n",
    "                + f_companies_pr[0]\n",
    "                + f_titles_pr[0]\n",
    "                + f_insts_pr[0]\n",
    "                + f_degrees_pr[0]\n",
    "                + f_fn[1]\n",
    "                + f_em[1]\n",
    "                + f_loc[1]\n",
    "                + f_sen[1]\n",
    "                + f_dom[1]\n",
    "                + f_skills_pr[1]\n",
    "                + f_companies_pr[1]\n",
    "                + f_titles_pr[1]\n",
    "                + f_insts_pr[1]\n",
    "                + f_degrees_pr[1]\n",
    "            )\n",
    "            / 20,\n",
    "            3,\n",
