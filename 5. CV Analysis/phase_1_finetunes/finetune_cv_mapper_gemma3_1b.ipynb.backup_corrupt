    "    ]\n",
    "    fuzzy_match_f1 = round(sum(fuzzy_f1_values) / len(fuzzy_f1_values), 3)\n",
    "\n",
    "    f_fn = (\n",
    "        fuzzy_seq_match(pred.full_name, true.full_name),\n",
    "        fuzzy_seq_match(pred.full_name, true.full_name),\n",
    "    )\n",
    "    f_em = (\n",
    "        fuzzy_seq_match(pred.email, true.email),\n",
    "        fuzzy_seq_match(pred.email, true.email),\n",
    "    )\n",
