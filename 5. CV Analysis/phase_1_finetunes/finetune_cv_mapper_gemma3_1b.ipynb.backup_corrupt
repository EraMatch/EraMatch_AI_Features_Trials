    "# %%\n",
    "# Cell 2 \u2014 Scoring Functions\n",
    "from __future__ import annotations\n",
    "import difflib\n",
    "from typing import Any, Dict, List, Optional, Set, Tuple\n",
    "\n",
    "FUZZY_MATCH_THRESHOLD = 0.8\n",
    "RANDOM_SEED = 42\n",
    "\n",
    "# ---\n",
    "\n",
    "\n",
    "def first_nonempty(*values):\n",
    "    for value in values:\n",
    "        if isinstance(value, str):\n",
    "            value = value.strip()\n",
    "            if value:\n",
    "                return value\n",
    "        elif value is not None:\n",
    "            return value\n",
    "    return None\n",
    "\n",
    "\n",
    "def normalize_prediction(pred: Optional[CVSchema]) -> Optional[CVSchema]:\n",
    "    if pred is None:\n",
    "        return None\n",
    "\n",
    "    contact = pred.contact_info\n",
    "    updates = {\n",
    "        \"full_name\": first_nonempty(\n",
    "            pred.full_name, contact.full_name if contact else None\n",
    "        ),\n",
    "        \"email\": first_nonempty(pred.email, contact.email if contact else None),\n",
    "        \"location\": first_nonempty(\n",
    "            pred.location, contact.location if contact else None\n",
    "        ),\n",
    "    }\n",
    "\n",
    "    if pred.has_github is None and contact and contact.github_url:\n",
    "        updates[\"has_github\"] = True\n",
    "    if pred.has_linkedin is None and contact and contact.linkedin_url:\n",
    "        updates[\"has_linkedin\"] = True\n",
    "\n",
    "    return pred.model_copy(update=updates)\n",
    "\n",
    "\n",
    "def set_f1(pred_set: set, true_set: set) -> float:\n",
    "    if not true_set and not pred_set:\n",
    "        return 1.0\n",
    "    if not true_set or not pred_set:\n",
    "        return 0.0\n",
    "    tp = len(pred_set & true_set)\n",
    "    precision = tp / len(pred_set)\n",
    "    recall = tp / len(true_set)\n",
    "    if precision + recall == 0:\n",
    "        return 0.0\n",
    "    return round(2 * precision * recall / (precision + recall), 3)\n",
    "\n",
    "\n",
    "def set_pr(pred_set: set, true_set: set) -> Tuple[float, float]:\n",
    "    if not true_set and not pred_set:\n",
    "        return (1.0, 1.0)\n",
    "    if not pred_set:\n",
    "        return (0.0, 0.0)\n",
    "    if not true_set:\n",
    "        return (0.0, 0.0)\n",
    "    tp = len(pred_set & true_set)\n",
    "    precision = round(tp / len(pred_set), 3)\n",
    "    recall = round(tp / len(true_set), 3)\n",
    "    return (precision, recall)\n",
    "\n",
    "\n",
    "try:\n",
    "    from Levenshtein import ratio as _lev_ratio\n",
    "\n",
    "    _LEVENSHTEIN_AVAILABLE = True\n",
    "except ImportError:\n",
    "    _LEVENSHTEIN_AVAILABLE = False\n",
    "\n",
    "\n",
    "def _str_similarity(a: str, b: str) -> float:\n",
    "    if _LEVENSHTEIN_AVAILABLE:\n",
    "        return _lev_ratio(a, b)\n",
    "    return difflib.SequenceMatcher(None, a, b).ratio()\n",
    "\n",
    "\n",
    "def fuzzy_seq_match(\n",
    "    pred: Optional[str], true: Optional[str], threshold: float = FUZZY_MATCH_THRESHOLD\n",
    ") -> float:\n",
    "    if true is None:\n",
    "        return 1.0 if pred is None else 0.0\n",
    "    if pred is None:\n",
    "        return 0.0\n",
    "    p = pred.lower().strip()\n",
    "    t = true.lower().strip()\n",
    "    if p == t:\n",
    "        return 1.0\n",
    "    return 1.0 if _str_similarity(p, t) >= threshold else 0.0\n",
    "\n",
    "\n",
    "def fuzzy_set_pr(\n",
    "    pred_set: set, true_set: set, threshold: float = FUZZY_MATCH_THRESHOLD\n",
    ") -> Tuple[float, float]:\n",
    "    if not true_set and not pred_set:\n",
    "        return (1.0, 1.0)\n",
    "    if not pred_set:\n",
    "        return (0.0, 0.0)\n",
    "    if not true_set:\n",
    "        return (0.0, 0.0)\n",
    "    matched_true: set = set()\n",
    "    matched_pred: set = set()\n",
    "    for p_item in sorted(pred_set):\n",
    "        best_score = 0.0\n",
    "        best_t = None\n",
    "        for t_item in true_set:\n",
    "            if t_item in matched_true:\n",
    "                continue\n",
    "            score = _str_similarity(p_item, t_item)\n",
    "            if score > best_score:\n",
    "                best_score = score\n",
    "                best_t = t_item\n",
    "        if best_score >= threshold and best_t is not None:\n",
    "            matched_true.add(best_t)\n",
    "            matched_pred.add(p_item)\n",
    "    precision = round(len(matched_pred) / len(pred_set), 3)\n",
    "    recall = round(len(matched_true) / len(true_set), 3)\n",
    "    return (precision, recall)\n",
    "\n",
    "\n",
    "def str_match(pred: Optional[str], true: Optional[str]) -> float:\n",
    "    if true is None:\n",
    "        return 1.0 if pred is None else 0.0\n",
    "    if pred is None:\n",
    "        return 0.0\n",
    "    return float(pred.strip().lower() == true.strip().lower())\n",
    "\n",
    "\n",
    "def fuzzy_match(pred: Optional[str], true: Optional[str]) -> float:\n",
    "    if true is None:\n",
    "        return 1.0 if pred is None else 0.0\n",
    "    if pred is None:\n",
    "        return 0.0\n",
    "    p = pred.lower().strip()\n",
    "    t = true.lower().strip()\n",
    "    return float(p in t or t in p)\n",
    "\n",
    "\n",
    "def levenshtein_distance(s1: str, s2: str) -> int:\n",
    "    if len(s1) < len(s2):\n",
    "        return levenshtein_distance(s2, s1)\n",
    "    if len(s2) == 0:\n",
    "        return len(s1)\n",
    "\n",
    "    previous_row = range(len(s2) + 1)\n",
    "    for i, c1 in enumerate(s1):\n",
    "        current_row = [i + 1]\n",
    "        for j, c2 in enumerate(s2):\n",
    "            insertions = previous_row[j + 1] + 1\n",
    "            deletions = current_row[j] + 1\n",
    "            substitutions = previous_row[j] + (c1 != c2)\n",
    "            current_row.append(min(insertions, deletions, substitutions))\n",
    "        previous_row = current_row\n",
    "    return previous_row[-1]\n",
    "\n",
    "\n",
    "def fuzzy_string_match(\n",
    "    pred: Optional[str], true: Optional[str], max_distance: int = 2\n",
    ") -> float:\n",
    "    if true is None:\n",
    "        return 1.0 if pred is None else 0.0\n",
    "    if pred is None:\n",
    "        return 0.0\n",
    "    p = pred.lower().strip()\n",
    "    t = true.lower().strip()\n",
    "    if p == t:\n",
    "        return 1.0\n",
    "    if len(t) == 0:\n",
    "        return 0.0\n",
    "    return 1.0 if levenshtein_distance(p, t) <= max_distance else 0.0\n",
    "\n",
    "\n",
    "def normalize_skill(skill: str) -> set:\n",
    "    skill = skill.lower().strip()\n",
    "    variations = {skill}\n",
    "    if \".\" in skill:\n",
    "        variations.add(skill.replace(\".\", \"\"))\n",
    "    if \"/\" in skill:\n",
    "        variations.update(part.strip() for part in skill.split(\"/\") if part.strip())\n",
    "    return variations\n",
    "\n",
    "\n",
    "def skill_set_f1(pred_skills: set, true_skills: set) -> Dict[str, float]:\n",
    "    if not true_skills and not pred_skills:\n",
    "        return {\n",
    "            \"exact_f1\": 1.0,\n",
    "            \"partial_f1\": 1.0,\n",
    "            \"combined_f1\": 1.0,\n",
    "            \"mrr\": 1.0,\n",
    "            \"exact_precision\": 1.0,\n",
    "            \"exact_recall\": 1.0,\n",
    "        }\n",
    "    if not true_skills or not pred_skills:\n",
    "        return {\n",
    "            \"exact_f1\": 0.0,\n",
    "            \"partial_f1\": 0.0,\n",
    "            \"combined_f1\": 0.0,\n",
    "            \"mrr\": 0.0,\n",
    "            \"exact_precision\": 0.0,\n",
    "            \"exact_recall\": 0.0,\n",
    "        }\n",
    "\n",
    "    tp_exact = len(pred_skills & true_skills)\n",
    "    precision_exact = tp_exact / len(pred_skills) if pred_skills else 0\n",
    "    recall_exact = tp_exact / len(true_skills) if true_skills else 0\n",
    "    exact_f1 = (\n",
    "        2 * precision_exact * recall_exact / (precision_exact + recall_exact)\n",
    "        if (precision_exact + recall_exact) > 0\n",
    "        else 0\n",
    "    )\n",
    "\n",
    "    pred_normalized = {frozenset(normalize_skill(s)) for s in pred_skills}\n",
    "    true_normalized = {frozenset(normalize_skill(s)) for s in true_skills}\n",
    "\n",
    "    tp_partial = 0\n",
    "    for pred_set in pred_normalized:\n",
    "        for true_set in true_normalized:\n",
    "            if set(pred_set) & set(true_set):\n",
    "                tp_partial += 1\n",
    "                break\n",
    "\n",
    "    tp_partial = min(tp_partial, len(true_skills))\n",
    "    precision_partial = tp_partial / len(pred_skills) if pred_skills else 0\n",
    "    recall_partial = tp_partial / len(true_skills) if true_skills else 0\n",
    "    partial_f1 = (\n",
    "        2 * precision_partial * recall_partial / (precision_partial + recall_partial)\n",
    "        if (precision_partial + recall_partial) > 0\n",
    "        else 0\n",
    "    )\n",
    "\n",
    "    combined_f1 = (exact_f1 + partial_f1) / 2\n",
    "    pred_list = list(pred_skills)\n",
    "    mrr = 0.0\n",
    "    for true_skill in true_skills:\n",
    "        for j, pred_skill in enumerate(pred_list):\n",
    "            if true_skill == pred_skill:\n",
    "                mrr = 1.0 / (j + 1)\n",
    "                break\n",
    "        if mrr > 0:\n",
    "            break\n",
    "\n",
    "    return {\n",
    "        \"exact_f1\": round(exact_f1, 3),\n",
    "        \"partial_f1\": round(partial_f1, 3),\n",
    "        \"combined_f1\": round(combined_f1, 3),\n",
    "        \"mrr\": round(mrr, 3),\n",
    "        \"exact_precision\": round(precision_exact, 3),\n",
    "        \"exact_recall\": round(recall_exact, 3),\n",
    "    }\n",
    "\n",
    "\n",
    "def score_cv(pred: Optional[CVSchema], true: CVSchema) -> Dict[str, float]:\n",
    "    pred = normalize_prediction(pred)\n",
    "    if pred is None:\n",
    "        return {\n",
    "            \"full_name\": 0.0,\n",
    "            \"email\": 0.0,\n",
    "            \"location\": 0.0,\n",
    "            \"seniority_level\": 0.0,\n",
    "            \"primary_domain\": 0.0,\n",
    "            \"years_of_experience\": 0.0,\n",
    "            \"has_github\": 0.0,\n",
    "            \"has_linkedin\": 0.0,\n",
    "            \"skills_exact_f1\": 0.0,\n",
    "            \"skills_partial_f1\": 0.0,\n",
    "            \"skills_combined_f1\": 0.0,\n",
    "            \"skills_mrr\": 0.0,\n",
    "            \"experience_companies_f1\": 0.0,\n",
    "            \"experience_titles_f1\": 0.0,\n",
    "            \"education_institutions_f1\": 0.0,\n",
    "            \"education_degrees_f1\": 0.0,\n",
    "            \"pydantic_valid\": 0.0,\n",
