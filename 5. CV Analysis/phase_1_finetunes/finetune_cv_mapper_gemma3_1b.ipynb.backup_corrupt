    "            \"primary_domain_precision\": 0.0,\n",
    "            \"primary_domain_recall\": 0.0,\n",
    "            \"years_of_experience_precision\": 0.0,\n",
    "            \"years_of_experience_recall\": 0.0,\n",
    "            \"has_github_precision\": 0.0,\n",
    "            \"has_github_recall\": 0.0,\n",
    "            \"has_linkedin_precision\": 0.0,\n",
    "            \"has_linkedin_recall\": 0.0,\n",
    "            \"skills_precision\": 0.0,\n",
    "            \"skills_recall\": 0.0,\n",
    "            \"experience_companies_precision\": 0.0,\n",
    "            \"experience_companies_recall\": 0.0,\n",
    "            \"experience_titles_precision\": 0.0,\n",
    "            \"experience_titles_recall\": 0.0,\n",
    "            \"education_institutions_precision\": 0.0,\n",
    "            \"education_institutions_recall\": 0.0,\n",
    "            \"education_degrees_precision\": 0.0,\n",
    "            \"education_degrees_recall\": 0.0,\n",
    "            \"hallucination_rate\": 0.0,\n",
    "            \"missing_field_rate\": 0.0,\n",
    "            \"fuzzy_full_name_precision\": 0.0,\n",
    "            \"fuzzy_full_name_recall\": 0.0,\n",
    "            \"fuzzy_email_precision\": 0.0,\n",
    "            \"fuzzy_email_recall\": 0.0,\n",
    "            \"fuzzy_location_precision\": 0.0,\n",
    "            \"fuzzy_location_recall\": 0.0,\n",
    "            \"fuzzy_seniority_level_precision\": 0.0,\n",
    "            \"fuzzy_seniority_level_recall\": 0.0,\n",
    "            \"fuzzy_primary_domain_precision\": 0.0,\n",
    "            \"fuzzy_primary_domain_recall\": 0.0,\n",
    "            \"fuzzy_years_of_experience_precision\": 0.0,\n",
    "            \"fuzzy_years_of_experience_recall\": 0.0,\n",
    "            \"fuzzy_has_github_precision\": 0.0,\n",
    "            \"fuzzy_has_github_recall\": 0.0,\n",
    "            \"fuzzy_has_linkedin_precision\": 0.0,\n",
    "            \"fuzzy_has_linkedin_recall\": 0.0,\n",
    "            \"fuzzy_skills_precision\": 0.0,\n",
    "            \"fuzzy_skills_recall\": 0.0,\n",
    "            \"fuzzy_experience_companies_precision\": 0.0,\n",
    "            \"fuzzy_experience_companies_recall\": 0.0,\n",
    "            \"fuzzy_experience_titles_precision\": 0.0,\n",
    "            \"fuzzy_experience_titles_recall\": 0.0,\n",
    "            \"fuzzy_education_institutions_precision\": 0.0,\n",
    "            \"fuzzy_education_institutions_recall\": 0.0,\n",
    "            \"fuzzy_education_degrees_precision\": 0.0,\n",
    "            \"fuzzy_education_degrees_recall\": 0.0,\n",
    "            \"fuzzy_match_f1\": 0.0,\n",
    "            \"fuzzy_full_name\": 0.0,\n",
    "            \"fuzzy_email\": 0.0,\n",
    "            \"fuzzy_location\": 0.0,\n",
    "            \"fuzzy_seniority_level\": 0.0,\n",
    "            \"fuzzy_primary_domain\": 0.0,\n",
    "        }\n",
    "\n",
    "    true_skills = {s.skill_name.lower() for s in true.skills if s and s.skill_name}\n",
    "    pred_skills = {\n",
    "        s.skill_name.lower() for s in (pred.skills or []) if s and s.skill_name\n",
    "    }\n",
    "\n",
    "    true_companies = {\n",
    "        e.company.lower() for e in true.work_experience if e and e.company\n",
    "    }\n",
    "    pred_companies = {\n",
    "        e.company.lower() for e in (pred.work_experience or []) if e and e.company\n",
    "    }\n",
    "\n",
    "    true_titles = {\n",
    "        e.job_title.lower() for e in true.work_experience if e and e.job_title\n",
    "    }\n",
    "    pred_titles = {\n",
    "        e.job_title.lower() for e in (pred.work_experience or []) if e and e.job_title\n",
    "    }\n",
    "\n",
    "    true_insts = {e.institution.lower() for e in true.education if e and e.institution}\n",
    "    pred_insts = {\n",
    "        e.institution.lower() for e in (pred.education or []) if e and e.institution\n",
    "    }\n",
    "\n",
    "    true_degrees = {e.degree.lower() for e in true.education if e and e.degree}\n",
    "    pred_degrees = {\n",
    "        e.degree.lower() for e in (pred.education or []) if e and e.degree\n",
    "    }\n",
    "\n",
    "    skill_scores = skill_set_f1(pred_skills, true_skills)\n",
    "\n",
    "    years_score = 0.0\n",
    "    if true.years_of_experience is not None and pred.years_of_experience is not None:\n",
    "        diff = abs(pred.years_of_experience - true.years_of_experience)\n",
    "        years_score = (\n",
    "            max(0.0, 1.0 - diff / true.years_of_experience)\n",
    "            if true.years_of_experience > 0\n",
    "            else 1.0\n",
    "        )\n",
    "\n",
    "    companies_pr = set_pr(pred_companies, true_companies)\n",
    "    titles_pr = set_pr(pred_titles, true_titles)\n",
    "    insts_pr = set_pr(pred_insts, true_insts)\n",
    "    degrees_pr = set_pr(pred_degrees, true_degrees)\n",
    "\n",
    "    fn_score = fuzzy_string_match(pred.full_name, true.full_name)\n",
    "    em_score = str_match(pred.email, true.email)\n",
    "    loc_score = fuzzy_match(pred.location, true.location)\n",
    "    sen_score = fuzzy_string_match(pred.seniority_level, true.seniority_level)\n",
    "    dom_score = fuzzy_match(pred.primary_domain, true.primary_domain)\n",
    "    yr_score = round(years_score, 3)\n",
    "    gh_score = float((pred.has_github or False) == (true.has_github or False))\n",
    "    li_score = float((pred.has_linkedin or False) == (true.has_linkedin or False))\n",
    "\n",
    "    # Hallucination rate: fraction of predicted items without GT match\n",
    "    hallucinated_count = 0\n",
    "    total_predicted_items = 0\n",
    "\n",
    "    for p_val, t_val in [\n",
    "        (pred.full_name, true.full_name),\n",
    "        (pred.email, true.email),\n",
    "        (pred.location, true.location),\n",
    "        (pred.seniority_level, true.seniority_level),\n",
    "        (pred.primary_domain, true.primary_domain),\n",
    "    ]:\n",
    "        if p_val is not None and str(p_val).strip():\n",
    "            total_predicted_items += 1\n",
    "            if t_val is None or not str(t_val).strip():\n",
    "                hallucinated_count += 1\n",
    "\n",
    "    for p_val, t_val in [\n",
    "        (pred.has_github, true.has_github),\n",
    "        (pred.has_linkedin, true.has_linkedin),\n",
    "    ]:\n",
    "        if p_val is not None:\n",
    "            total_predicted_items += 1\n",
    "            if p_val != t_val:\n",
    "                hallucinated_count += 1\n",
    "\n",
    "    if pred.years_of_experience is not None:\n",
    "        total_predicted_items += 1\n",
    "        if true.years_of_experience is None or years_score == 0.0:\n",
    "            hallucinated_count += 1\n",
    "\n",
    "    # Set fields: predicted items absent from GT count as hallucinated\n",
    "    for pred_set, true_set in [\n",
    "        (pred_skills, true_skills),\n",
    "        (pred_companies, true_companies),\n",
    "        (pred_titles, true_titles),\n",
    "        (pred_insts, true_insts),\n",
    "        (pred_degrees, true_degrees),\n",
    "    ]:\n",
    "        total_predicted_items += len(pred_set)\n",
    "        hallucinated_count += len(pred_set - true_set)\n",
    "\n",
    "    hallucination_rate = (\n",
    "        round(hallucinated_count / total_predicted_items, 3)\n",
    "        if total_predicted_items > 0\n",
    "        else 0.0\n",
    "    )\n",
    "\n",
    "    # Missing-field rate: GT items absent from prediction\n",
    "    missing_count = 0\n",
    "    total_gt_items = 0\n",
    "\n",
    "    # String fields: non-null GT with null/wrong prediction counts as missing\n",
    "    for p_val, t_val in [\n",
    "        (pred.full_name, true.full_name),\n",
    "        (pred.email, true.email),\n",
    "        (pred.location, true.location),\n",
    "        (pred.seniority_level, true.seniority_level),\n",
    "        (pred.primary_domain, true.primary_domain),\n",
    "    ]:\n",
    "        if t_val is not None and str(t_val).strip():\n",
    "            total_gt_items += 1\n",
    "            if p_val is None or not str(p_val).strip():\n",
    "                missing_count += 1\n",
    "\n",
    "    # Boolean fields\n",
    "    for p_val, t_val in [\n",
    "        (pred.has_github, true.has_github),\n",
