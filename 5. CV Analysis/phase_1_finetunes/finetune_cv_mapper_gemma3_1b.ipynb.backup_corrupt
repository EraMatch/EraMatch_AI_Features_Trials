    "        total_gt_items += 1\n",
    "        if pred.years_of_experience is None or years_score == 0.0:\n",
    "            missing_count += 1\n",
    "\n",
    "    # Set fields: items in true not found in pred\n",
    "    for pred_set, true_set in [\n",
